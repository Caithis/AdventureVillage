config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Dungeon Frontier Guild-Town (4.6)"
config/description="A 2D pixel-art frontier guild-town management simulation."
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameClock="*res://scripts/autoload/GameClock.gd"
GameState="*res://scripts/autoload/GameState.gd"
SceneRouter="*res://scripts/autoload/SceneRouter.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=720

[rendering]

textures/canvas_textures/default_texture_filter=0
